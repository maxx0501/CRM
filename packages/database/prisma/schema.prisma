generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Multi-tenancy ────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String?
  image        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships WorkspaceMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  niche            String?
  timezone         String   @default("America/Sao_Paulo")
  whatsappApiUrl   String?
  whatsappApiKey   String?
  googleCalendarId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members       WorkspaceMember[]
  pipelines     Pipeline[]
  leads         Lead[]
  appointments  Appointment[]
  conversations Conversation[]
  transactions  Transaction[]
  campaigns     Campaign[]
  automations   Automation[]
  tags          Tag[]
  customFields  CustomFieldDef[]
}

enum MemberRole {
  OWNER
  MEMBER
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String
  role        MemberRole @default(MEMBER)
  createdAt   DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

// ─── Kanban Pipeline ─────────────────────────────────────────

model Pipeline {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages    PipelineStage[]

  @@index([workspaceId])
}

model PipelineStage {
  id          String  @id @default(cuid())
  pipelineId  String
  name        String
  color       String  @default("#6366f1")
  position    Int
  isWonStage  Boolean @default(false)
  isLostStage Boolean @default(false)

  pipeline    Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads       Lead[]
  automations Automation[] @relation("TriggerStage")

  @@index([pipelineId])
}

// ─── Leads ───────────────────────────────────────────────────

enum LeadSource {
  MANUAL
  WHATSAPP
  WEBSITE
  REFERRAL
  INSTAGRAM
  FACEBOOK
  GOOGLE
  OTHER
}

model Lead {
  id          String     @id @default(cuid())
  workspaceId String
  stageId     String
  name        String
  email       String?
  phone       String?
  source      LeadSource @default(MANUAL)
  score       Int        @default(0)
  value       Decimal?   @db.Decimal(10, 2)
  position    Int        @default(0)

  // UTM tracking
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  campaignId  String?

  wonAt   DateTime?
  lostAt  DateTime?
  lostReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stage        PipelineStage      @relation(fields: [stageId], references: [id])
  campaign     Campaign?          @relation(fields: [campaignId], references: [id])
  notes        Note[]
  tags         LeadTag[]
  activities   Activity[]
  customValues CustomFieldValue[]
  appointments Appointment[]
  conversations Conversation[]
  transactions Transaction[]
  enrollments  AutomationEnrollment[]

  @@index([workspaceId])
  @@index([stageId])
  @@index([workspaceId, source])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Tag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads     LeadTag[]

  @@unique([workspaceId, name])
}

model LeadTag {
  leadId String
  tagId  String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
}

enum ActivityType {
  NOTE_ADDED
  STAGE_CHANGED
  TAG_ADDED
  TAG_REMOVED
  APPOINTMENT_CREATED
  APPOINTMENT_COMPLETED
  MESSAGE_SENT
  MESSAGE_RECEIVED
  PAYMENT_RECEIVED
  LEAD_CREATED
  SCORE_CHANGED
  FIELD_UPDATED
}

model Activity {
  id          String       @id @default(cuid())
  leadId      String
  type        ActivityType
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([leadId, createdAt])
}

// ─── Custom Fields ───────────────────────────────────────────

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTISELECT
  BOOLEAN
}

model CustomFieldDef {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  fieldType   FieldType
  options     Json?     // For SELECT/MULTISELECT: ["option1", "option2"]
  isRequired  Boolean   @default(false)
  position    Int       @default(0)
  createdAt   DateTime  @default(now())

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  values    CustomFieldValue[]

  @@unique([workspaceId, name])
}

model CustomFieldValue {
  id      String @id @default(cuid())
  leadId  String
  fieldId String
  value   String @db.Text

  lead  Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  field CustomFieldDef @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([leadId, fieldId])
}

// ─── Appointments ────────────────────────────────────────────

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Appointment {
  id              String            @id @default(cuid())
  workspaceId     String
  leadId          String?
  title           String
  startsAt        DateTime
  endsAt          DateTime
  status          AppointmentStatus @default(SCHEDULED)
  googleEventId   String?
  reminderSentAt  DateTime?
  notes           String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, startsAt])
}

// ─── WhatsApp ────────────────────────────────────────────────

model Conversation {
  id            String   @id @default(cuid())
  workspaceId   String
  leadId        String?
  whatsappPhone String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id])
  messages  Message[]

  @@unique([workspaceId, whatsappPhone])
  @@index([workspaceId])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  direction      MessageDirection
  content        String?          @db.Text
  mediaUrl       String?
  status         MessageStatus    @default(PENDING)
  externalId     String?
  createdAt      DateTime         @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// ─── Finances ────────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BANK_TRANSFER
  OTHER
}

model Transaction {
  id          String        @id @default(cuid())
  workspaceId String
  leadId      String?
  type        TransactionType
  description String
  amount      Decimal       @db.Decimal(10, 2)
  method      PaymentMethod @default(PIX)
  isPaid      Boolean       @default(false)
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, type])
}

// ─── Campaigns ───────────────────────────────────────────────

model Campaign {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  budget      Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leads     Lead[]

  @@index([workspaceId])
}

// ─── Automations ─────────────────────────────────────────────

model Automation {
  id             String  @id @default(cuid())
  workspaceId    String
  name           String
  triggerStageId String?
  triggerSource  LeadSource?
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace    Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  triggerStage PipelineStage?         @relation("TriggerStage", fields: [triggerStageId], references: [id])
  steps        AutomationStep[]
  enrollments  AutomationEnrollment[]

  @@index([workspaceId])
}

model AutomationStep {
  id              String @id @default(cuid())
  automationId    String
  position        Int
  delayMinutes    Int    @default(0)
  messageTemplate String @db.Text

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
}

model AutomationEnrollment {
  id           String   @id @default(cuid())
  automationId String
  leadId       String
  currentStep  Int      @default(0)
  nextRunAt    DateTime?
  isCompleted  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  lead       Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([automationId, leadId])
  @@index([isCompleted, nextRunAt])
}
